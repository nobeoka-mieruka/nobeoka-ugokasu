# このファイルをコピーして .dev.vars を作成すると、`npm run dev:pages`
# （wrangler pages dev）実行時にCloudflare Pages Functionsのローカル環境変数・
# Secretsとして読み込まれます。
#
# .dev.vars は絶対にGitHubへコミットしないでください（.gitignoreで除外済み）。
# このファイル（.dev.vars.example）には実際のID・トークンを記載しないでください。

META_GRAPH_API_VERSION=v21.0
FACEBOOK_PAGE_ID=
INSTAGRAM_USER_ID=
META_ACCESS_TOKEN=
FACEBOOK_PAGE_URL=https://www.facebook.com/profile.php?id=61591967011155
INSTAGRAM_PROFILE_URL=https://www.instagram.com/chie_smily4/
INSTAGRAM_USERNAME=chie_smily4
SOCIAL_SYNC_SECRET=
SOCIAL_POST_LIMIT=6
