# このファイルをコピーして .env を作成し、必要な値だけ設定してください。
# .env は絶対にGitHubへコミットしないでください（.gitignoreで除外済み）。
# 空欄のままでもサイトは正常に動作します（該当機能が非表示になるだけです）。

# Google Search Console 所有権確認コード（HTMLタグのcontent値）
PUBLIC_GSC_VERIFICATION=

# Bing Webmaster Tools 所有権確認コード
PUBLIC_BING_VERIFICATION=

# Google Analytics 4 測定ID（例: G-XXXXXXXXXX）
PUBLIC_GA4_ID=

# Cloudflare Web Analytics トークン
PUBLIC_CF_ANALYTICS_TOKEN=
