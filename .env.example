# このファイルをコピーして .env を作成し、必要な値だけ設定してください。
# .env は絶対にGitHubへコミットしないでください（.gitignoreで除外済み）。
# 空欄のままでもサイトは正常に動作します（該当機能が非表示になるだけです）。

# Google Search Console 所有権確認コード（HTMLタグのcontent値）
PUBLIC_GSC_VERIFICATION=

# Bing Webmaster Tools 所有権確認コード
PUBLIC_BING_VERIFICATION=

# Google Analytics 4 測定ID（例: G-XXXXXXXXXX）
PUBLIC_GA4_ID=

# Cloudflare Web Analytics トークン
PUBLIC_CF_ANALYTICS_TOKEN=

# =============================================================
# 以下はSNS自動連携（Facebook/Instagram投稿の自動取得）に使う値です。
# これらはこの.envファイルには実際の値を書き込まないでください。
# アクセストークン等の秘密情報は、必ずCloudflareの
# 「Pages > 設定 > 環境変数（暗号化）」および
# ワーカー側は `wrangler secret put <名前>` で登録します。
# 詳しい手順は docs/social-sync-setup.md を参照してください。
# =============================================================

# Meta Graph APIのバージョン（例: v21.0）。秘密情報ではありません。
META_GRAPH_API_VERSION=

# 「福富千恵と延岡を動かす会」FacebookページのページID。秘密情報ではありませんが、
# Cloudflare側の環境変数として設定してください。
FACEBOOK_PAGE_ID=

# Facebookページの投稿を取得するためのページアクセストークン（秘密情報）
FACEBOOK_PAGE_ACCESS_TOKEN=

# InstagramプロアカウントのビジネスアカウントID。秘密情報ではありません。
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Instagramの投稿を取得するためのアクセストークン（秘密情報）
INSTAGRAM_ACCESS_TOKEN=

# 手動同期エンドポイント（/api/admin/sync-social-posts）を保護する秘密キー
SOCIAL_SYNC_SECRET=

# 一度に保存・表示するSNS投稿の最大件数（初期値12）
SOCIAL_POST_LIMIT=12
