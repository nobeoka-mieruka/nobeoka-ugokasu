# このファイルをコピーして .env を作成し、必要な値だけ設定してください。
# .env は絶対にGitHubへコミットしないでください（.gitignoreで除外済み）。
# 空欄のままでもサイトは正常に動作します（該当機能が非表示になるだけです）。

# Google Search Console 所有権確認コード（HTMLタグのcontent値）
PUBLIC_GSC_VERIFICATION=

# Bing Webmaster Tools 所有権確認コード
PUBLIC_BING_VERIFICATION=

# Google Analytics 4 測定ID（例: G-XXXXXXXXXX）
PUBLIC_GA4_ID=

# Cloudflare Web Analytics トークン
PUBLIC_CF_ANALYTICS_TOKEN=

# =============================================================
# 以下はFacebook・Instagramの公式アカウント情報です（src/config/socialConfig.ts）。
# 秘密情報ではありません。未設定でも既定値（正式URL）でビルド・表示されます。
# =============================================================

# 公式FacebookページURL
FACEBOOK_PAGE_URL=https://www.facebook.com/profile.php?id=61591967011155

# 公式InstagramプロフィールURL
INSTAGRAM_PROFILE_URL=https://www.instagram.com/chie_smily4/

# Instagramのユーザーネーム（表示用。@を付けずに入力）
INSTAGRAM_USERNAME=chie_smily4

# =============================================================
# 以下はSNS自動連携（Facebook/Instagram投稿の自動取得）に使う値です。
# これらはこの.envファイルには実際の値を書き込まないでください
# （ローカルでPages Functionsを試す場合は、代わりに.dev.vars を使用します。
# .dev.vars.example をコピーして .dev.vars を作成してください）。
# アクセストークン等の秘密情報は、必ずCloudflareの
# 「Pages > 設定 > Variables and Secrets（Secretsとして登録）」および
# ワーカー側は `wrangler secret put <名前>` で登録します。
# 詳しい手順は docs/social-sync-setup.md と META_SOCIAL_SETUP.md を参照してください。
# =============================================================

# Meta Graph APIのバージョン（例: v21.0）。秘密情報ではありません。
# コード内に固定値を書かず、必ずこの変数から取得する構成にしています。
META_GRAPH_API_VERSION=

# 「福富千恵と延岡を動かす会」FacebookページのページID。秘密情報ではありませんが、
# Cloudflare側の環境変数として設定してください。
FACEBOOK_PAGE_ID=

# Facebookページの投稿を取得するためのページアクセストークン（Secret）
FACEBOOK_PAGE_ACCESS_TOKEN=

# InstagramプロアカウントのユーザーID（Graph API用の数字のID）。秘密情報ではありません。
# 上記のINSTAGRAM_USERNAME（ユーザーネーム）とは別の値です。ユーザーネームから
# 推測せず、Meta側で確認した正式な値を登録してください。
INSTAGRAM_USER_ID=

# Instagramの投稿を取得するためのアクセストークン（Secret）
INSTAGRAM_ACCESS_TOKEN=

# 手動同期エンドポイント（/api/admin/sync-social-posts）を保護する秘密キー（Secret）
SOCIAL_SYNC_SECRET=

# 1プラットフォームあたりに取得・保存するSNS投稿の最大件数（初期値6。合算最大は約2倍の12件）
SOCIAL_POST_LIMIT=6
