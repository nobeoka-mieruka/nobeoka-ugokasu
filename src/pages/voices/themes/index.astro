---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import HeroSection from "../../../components/HeroSection.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import VoiceThemeCard from "../../../components/VoiceThemeCard.astro";
import { voiceThemes } from "../../../data/voiceThemes";
import { webPageSchema } from "../../../utils/structuredData";
import { buildBreadcrumbList } from "../../../utils/seo";

const title = "意見募集中のテーマ｜みんなの声｜福富千恵と延岡を動かす会";
const description = "福富千恵と延岡を動かす会が意見を募集しているテーマの一覧です。福祉、子育て、防災など幅広い分野で市民の声を集めています。";
const breadcrumbItems = [
  { name: "みんなの声", path: "/voices" },
  { name: "意見募集中のテーマ", path: "/voices/themes" },
];

const schemas = [
  webPageSchema({ path: "/voices/themes", name: title, description }),
  buildBreadcrumbList(breadcrumbItems),
];
---

<BaseLayout title={title} description={description} path="/voices/themes" schemas={schemas}>
  <Breadcrumb items={breadcrumbItems} />
  <HeroSection title="意見募集中のテーマ" eyebrow="みんなの声" description="分野ごとに、皆さまのご意見を募集しています。" />

  <section class="py-14 sm:py-20">
    <div class="section-wrap">
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {voiceThemes.map((theme) => (
          <VoiceThemeCard theme={theme} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
