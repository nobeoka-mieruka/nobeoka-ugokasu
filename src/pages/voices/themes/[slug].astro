---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import HeroSection from "../../../components/HeroSection.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import VoiceStatusBadge from "../../../components/VoiceStatusBadge.astro";
import VoiceReportCard from "../../../components/VoiceReportCard.astro";
import Icon from "../../../components/Icon.astro";
import { voiceThemes, getVoiceTheme } from "../../../data/voiceThemes";
import { voicesConfig } from "../../../config/voicesConfig";
import { webPageSchema } from "../../../utils/structuredData";
import { buildBreadcrumbList } from "../../../utils/seo";

export async function getStaticPaths() {
  return voiceThemes.map((theme) => ({ params: { slug: theme.slug } }));
}

const { slug } = Astro.params;
const theme = getVoiceTheme(slug!)!;

const title = `${theme.title}に関するご意見｜みんなの声｜福富千恵と延岡を動かす会`;
const description = `${theme.title}に関する市民の皆さまのご意見を募集しています。${theme.description}`;
const path = `/voices/themes/${theme.slug}`;
const breadcrumbItems = [
  { name: "みんなの声", path: "/voices" },
  { name: "意見募集中のテーマ", path: "/voices/themes" },
  { name: theme.title, path },
];

const reports = (await getCollection("voice-reports", ({ data }) => data.published)).filter(
  (r) => r.data.theme === theme.title,
);

const schemas = [
  webPageSchema({ path, name: title, description }),
  buildBreadcrumbList(breadcrumbItems),
];
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  <Breadcrumb items={breadcrumbItems} />
  <HeroSection title={theme.title} eyebrow="意見募集中のテーマ" description={theme.description} />

  <section class="py-14 sm:py-20">
    <div class="section-wrap max-w-3xl">
      <div class="card flex flex-wrap items-center justify-between gap-3 mb-8">
        <VoiceStatusBadge status={theme.status} />
        {theme.period ? (
          <span class="text-sm text-ink-soft">募集期間：{theme.period}</span>
        ) : (
          <span class="text-sm text-ink-soft">募集期間は未定です。決まり次第お知らせします。</span>
        )}
      </div>

      <p class="text-ink leading-relaxed mb-2">
        このテーマに関するお困りごと、ご意見、改善してほしいこと、延岡市への提案などをお寄せください。
      </p>
      {theme.examples && (
        <p class="text-sm text-ink-soft mb-6">相談例：{theme.examples}</p>
      )}

      <p class="text-sm text-ink-soft leading-relaxed mb-8">
        いただいたご意見は、今後の政策提言や地域課題の整理の参考にさせていただきます。
      </p>

      <div class="mb-8">
        {voicesConfig.googleFormUrl ? (
          <a href={voicesConfig.googleFormUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
            このテーマについて意見を送る
            <Icon name="external-link" class="w-4 h-4" ariaHidden={true} />
            <span class="sr-only">（新しいタブで開く）</span>
          </a>
        ) : (
          <div class="card text-center py-10 flex flex-col items-center gap-3">
            <Icon name="document" class="w-8 h-8 text-brand-orange" />
            <p class="text-ink-soft">現在、意見受付フォームを準備しています。</p>
          </div>
        )}
      </div>

      <h2 class="font-bold text-ink text-lg mb-4">この分野の分析結果</h2>
      {reports.length > 0 ? (
        <div class="grid gap-4 sm:grid-cols-2">
          {reports.map((r) => (
            <VoiceReportCard slug={r.slug} title={r.data.title} theme={r.data.theme} lastUpdated={r.data.lastUpdated} responseCount={r.data.responseCount} />
          ))}
        </div>
      ) : (
        <div class="card text-center py-10 flex flex-col items-center gap-3 text-ink-soft">
          <Icon name="document" class="w-8 h-8 text-brand-orange" />
          <p>この分野の分析結果は準備中です。</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
