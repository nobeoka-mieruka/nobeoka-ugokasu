---
import BaseLayout from "../../layouts/BaseLayout.astro";
import VoiceHero from "../../components/VoiceHero.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import SectionTitle from "../../components/SectionTitle.astro";
import RelatedContent from "../../components/RelatedContent.astro";
import Icon from "../../components/Icon.astro";
import VoiceEngagementFlow from "../../components/VoiceEngagementFlow.astro";
import VoiceSummaryPanel from "../../components/VoiceSummaryPanel.astro";
import { voicesConfig } from "../../config/voicesConfig";
import { voiceThemes } from "../../data/voiceThemes";
import { webPageSchema } from "../../utils/structuredData";
import { buildBreadcrumbList } from "../../utils/seo";

const title = "延岡の課題と市民の声｜福富千恵と延岡を動かす会";
const description = "福富千恵と延岡を動かす会の「みんなの声（ブロードリスニング）」のご紹介です。市民の皆さまの声を集め、整理し、対応状況を公開しています。";
const breadcrumbItems = [{ name: "みんなの声", path: "/voices" }];

const schemas = [
  webPageSchema({ path: "/voices", name: title, description }),
  buildBreadcrumbList(breadcrumbItems),
];
---

<BaseLayout title={title} description={description} path="/voices" schemas={schemas}>
  <Breadcrumb items={breadcrumbItems} />
  <VoiceHero
    title={"あなたの声から、\n延岡のこれからを考えます。"}
    description="多様な声を幅広く集め、共通する課題、異なる立場からの意見、少数でも重要な意見を整理し、今後の活動や提言に生かす取り組みです。単なる多数決や人気投票ではありません。"
  />

  <section class="py-14 sm:py-20">
    <div class="section-wrap max-w-4xl">
      <div class="grid gap-6 sm:grid-cols-2">
        <a href="/voices/submit/" class="card hover:shadow-md transition-shadow flex flex-col gap-2">
          <Icon name="megaphone" class="w-8 h-8 text-brand-orange" />
          <h2 class="font-bold text-ink text-lg">声を届ける</h2>
          <p class="text-sm text-ink-soft">ご意見やお困りごとをお寄せください。</p>
        </a>
        <a href="/voices/themes/" class="card hover:shadow-md transition-shadow flex flex-col gap-2">
          <Icon name="document" class="w-8 h-8 text-brand-orange" />
          <h2 class="font-bold text-ink text-lg">意見募集中のテーマ</h2>
          <p class="text-sm text-ink-soft">現在募集しているテーマの一覧です。</p>
        </a>
        <a href="/voices/reports/" class="card hover:shadow-md transition-shadow flex flex-col gap-2">
          <Icon name="users" class="w-8 h-8 text-brand-orange" />
          <h2 class="font-bold text-ink text-lg">分析結果一覧</h2>
          <p class="text-sm text-ink-soft">集まった声の分析結果を公開しています。</p>
        </a>
        <a href="/voices/method/" class="card hover:shadow-md transition-shadow flex flex-col gap-2">
          <Icon name="handshake" class="w-8 h-8 text-brand-orange" />
          <h2 class="font-bold text-ink text-lg">声の集め方・整理方法</h2>
          <p class="text-sm text-ink-soft">どのように集め、整理しているかをご説明します。</p>
        </a>
      </div>
    </div>
  </section>

  <section class="py-14 sm:py-20 bg-brand-ivory">
    <div class="section-wrap max-w-4xl">
      <SectionTitle title="受付から反映までの流れ" align="left" />
      <VoiceEngagementFlow />
    </div>
  </section>

  <section class="py-14 sm:py-20">
    <div class="section-wrap max-w-4xl">
      <SectionTitle title="受付状況" align="left" />
      <VoiceSummaryPanel />
    </div>
  </section>

  <section class="py-14 sm:py-20 bg-brand-ivory">
    <div class="section-wrap max-w-4xl">
      <SectionTitle title="現在寄せられている主なテーマ" align="left" />
      <p class="text-ink-soft leading-relaxed mb-6">
        以下のテーマで意見を募集しています。テーマごとの件数は集計中です。
      </p>
      <ul class="flex flex-wrap gap-2">
        {voiceThemes.map((theme) => (
          <li>
            <a
              href={`/voices/themes/${theme.slug}/`}
              class="inline-flex items-center gap-2 rounded-full bg-white ring-1 ring-black/10 px-4 py-2 text-sm font-bold text-ink hover:ring-brand-orange-dark hover:bg-brand-orange-light transition-colors"
            >
              {theme.title}
              <span class="text-xs font-normal text-ink-soft">集計中</span>
            </a>
          </li>
        ))}
      </ul>
      <div class="mt-6">
        <a href="/voices/themes/" class="btn-secondary">テーマ一覧を見る</a>
      </div>
    </div>
  </section>

  <section class="py-14 sm:py-20">
    <div class="section-wrap max-w-4xl">
      <SectionTitle title="対応状況について" align="left" />
      <p class="text-ink-soft leading-relaxed mb-4">
        寄せられたご意見への対応状況は、以下のいずれかの状態で管理・公開しています。
      </p>
      <ul class="grid gap-2 sm:grid-cols-3">
        {voicesConfig.responseStatusLabels.map((label) => (
          <li class="card py-3 text-center text-sm font-bold text-ink">{label}</li>
        ))}
      </ul>
      <p class="mt-4 text-sm text-ink-soft">
        「現時点では対応が困難です」とする場合は、可能な範囲で理由もあわせて公開します。
      </p>
    </div>
  </section>

  <div class="section-wrap">
    <RelatedContent
      items={[
        { title: "私たちの提言", href: "/vision", description: "寄せられた声は今後の提言の参考にします。" },
        { title: "福富千恵について", href: "/profile", description: "福富千恵の経験と提言の背景をご紹介します。" },
        { title: "延岡市役所 どこに行けばいい？診断", href: "/city-guide", description: "行政手続きに関するお困りごとは、こちらの窓口案内もご活用ください。" },
      ]}
    />
  </div>
</BaseLayout>
