---
import { getCollection } from "astro:content";
import { Picture, getImage } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionTitle from "../components/SectionTitle.astro";
import MessageCard from "../components/MessageCard.astro";
import ProfileSummary from "../components/ProfileSummary.astro";
import VisionCard from "../components/VisionCard.astro";
import ActivityCard from "../components/ActivityCard.astro";
import NewsCard from "../components/NewsCard.astro";
import ContactBanner from "../components/ContactBanner.astro";
import Icon from "../components/Icon.astro";
import VideoCard from "../components/VideoCard.astro";
import { siteConfig } from "../config/siteConfig";
import { visionHeading, visionSubtitle, visionProposals } from "../data/vision";
import { videos } from "../data/videos";
import { organizationSchema, personSchema, websiteSchema, webPageSchema } from "../utils/structuredData";
import fukutomiChiePortrait from "../assets/images/profile/fukutomi-chie.jpg";

const title = "福富千恵と延岡を動かす会｜あなたと、延岡を動かす";
const description =
  "福富千恵と延岡を動かす会の公式ホームページ。福富千恵のプロフィール、延岡への提言、活動報告、みんなの声（ブロードリスニング）を発信しています。";

// OGP（SNSシェア時）専用のタイトル・説明文
const ogTitle = "福富千恵と延岡を動かす会｜あなたと、延岡を動かす！";
const ogDescription =
  "福富千恵のプロフィール、活動報告、提言、市民の声（ブロードリスニング）を掲載する公式ホームページです。";

const activities = (await getCollection("activities", ({ data }) => data.published))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const news = (await getCollection("news", ({ data }) => data.published))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const featuredVideos = videos.filter((v) => v.featured).slice(0, 3);

const schemas = [
  websiteSchema(),
  organizationSchema(),
  personSchema({ image: "/images/profile/fukutomi-chie-800.jpg" }),
  webPageSchema({ path: "/", name: title, description, image: siteConfig.defaultOgpImage }),
];

// LCP対策：メインビジュアルの人物写真は、実際に表示される幅（コンテナのpaddingを
// 差し引いた幅）にsizesを一致させ、同じ内容でpreloadすることで発見・取得を早める。
// 620px（lg以上）はPicture側の値と一致させたもの。
const heroImageWidths = [400, 560, 700, 900, 1134];
const heroImageSizes =
  "(min-width: 1024px) 620px, (min-width: 768px) calc(100vw - 112px), (min-width: 640px) calc(100vw - 96px), calc(100vw - 64px)";
const heroImageAvifVariants = await Promise.all(
  heroImageWidths.map((width) => getImage({ src: fukutomiChiePortrait, format: "avif", width })),
);
const heroImageSrcset = heroImageAvifVariants.map((img, i) => `${img.src} ${heroImageWidths[i]}w`).join(", ");
---

<BaseLayout
  title={title}
  description={description}
  path="/"
  ogType="website"
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  ogImage={siteConfig.defaultOgpImage}
  schemas={schemas}
>
  <Fragment slot="head">
    <!--
      LCP対策：メインビジュアルの人物写真（AVIF）を、実際に表示される候補と
      同じsrcset/sizesでpreloadし、発見・取得を早める。
    -->
    <link
      rel="preload"
      as="image"
      type="image/avif"
      imagesrcset={heroImageSrcset}
      imagesizes={heroImageSizes}
      fetchpriority="high"
    />
  </Fragment>
  <!-- 8-1 メインビジュアル -->
  <section class="bg-gradient-to-b from-brand-orange-light to-white">
    <div class="section-wrap py-12 sm:py-20">
      <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
        <div class="order-2 lg:order-1">
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-ink leading-snug">
            私も悩み、<br />
            <span class="text-brand-orange-dark">支えられながら</span><br />
            歩いてきました。
          </h1>
          <p class="mt-5 text-xl sm:text-2xl text-ink-soft leading-relaxed">
            だからこそ、<br />
            わかる思いがあります。
          </p>
          <p class="mt-8 text-[40px] sm:text-[52px] lg:text-[56px] leading-[1.15] font-bold text-brand-orange-dark">
            <span class="whitespace-nowrap">あなたと、</span><span class="whitespace-nowrap">延岡を動かす！</span>
          </p>
          <div class="mt-8">
            <p class="text-2xl font-bold text-ink">福富 千恵</p>
            <p class="text-base text-ink-soft">ふくとみ ちえ</p>
          </div>
          <div class="mt-10 flex flex-wrap gap-4">
            <a href="/profile/" class="btn-primary">福富千恵について</a>
            <a href="/vision/" class="btn-secondary">私たちの提言</a>
            <a href="/voices/" class="btn-secondary">みんなの声</a>
            <a href="/activities/" class="btn-secondary">活動報告を見る</a>
          </div>
        </div>
        <div class="order-1 lg:order-2 relative rounded-[2rem] overflow-hidden p-4 sm:p-6 md:p-8 lg:p-10">
          <div class="pointer-events-none absolute inset-0 z-0" aria-hidden="true">
            <!--
              LCP対策：この装飾イラストは<img>で外部SVGファイルを読み込んでいたため、
              paddingの影響を受けない absolute inset-0 の描画面積が写真より大きくなり、
              Chromeが（写真ではなく）この装飾を最大コンテンツ（LCP）として判定していた。
              ベクター図形のみのSVGなのでインライン化し、画像リソースとして扱われないようにする
              （見た目・レイアウトは変更なし。object-fit/object-positionはinline SVGにも適用される）。
            -->
            <svg
              viewBox="0 0 800 600"
              class="w-full h-full object-cover opacity-45 [object-position:center_bottom]"
              aria-hidden="true"
            >
              <defs>
                <linearGradient id="hero-sky" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#FFF9EF" />
                  <stop offset="100%" stop-color="#FFE7CE" />
                </linearGradient>
                <linearGradient id="hero-river" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#BFE0EC" />
                  <stop offset="100%" stop-color="#9FCEDF" />
                </linearGradient>
                <radialGradient id="hero-sun" cx="50%" cy="50%" r="50%">
                  <stop offset="0%" stop-color="#FFD9A8" stop-opacity="0.9" />
                  <stop offset="100%" stop-color="#FFD9A8" stop-opacity="0" />
                </radialGradient>
              </defs>

              <rect x="0" y="0" width="800" height="600" fill="url(#hero-sky)" />

              <circle cx="640" cy="120" r="150" fill="url(#hero-sun)" />
              <circle cx="640" cy="120" r="46" fill="#FFEDD6" />

              <g fill="#F3C8B4" opacity="0.55">
                <ellipse cx="150" cy="150" rx="70" ry="20" />
                <ellipse cx="230" cy="130" rx="55" ry="16" />
                <ellipse cx="560" cy="200" rx="60" ry="17" />
              </g>

              <path
                d="M0 330 L90 260 L170 320 L260 250 L360 320 L460 260 L560 320 L660 270 L740 320 L800 290 L800 420 L0 420 Z"
                fill="#CFE7CE"
                opacity="0.65"
              />
              <path
                d="M0 360 L120 300 L230 355 L340 295 L470 360 L600 300 L720 355 L800 330 L800 440 L0 440 Z"
                fill="#AED7AE"
                opacity="0.55"
              />

              <path
                d="M0 430 C 140 400, 220 460, 360 430 C 500 400, 600 460, 800 425 L800 470 C 600 500, 500 445, 360 470 C 220 495, 140 440, 0 470 Z"
                fill="url(#hero-river)"
                opacity="0.75"
              />

              <g opacity="0.6" stroke="#D9530B" stroke-width="4" fill="none" stroke-linecap="round">
                <path d="M330 432 Q 400 392 470 432" />
                <line x1="330" y1="432" x2="330" y2="452" />
                <line x1="400" y1="415" x2="400" y2="452" />
                <line x1="470" y1="432" x2="470" y2="452" />
              </g>

              <g opacity="0.7">
                <rect x="40" y="360" width="46" height="90" fill="#FBD8BE" />
                <rect x="96" y="330" width="40" height="120" fill="#F6C6A3" />
                <polygon points="96,330 116,305 136,330" fill="#E39A6E" />
                <rect x="150" y="380" width="36" height="70" fill="#FBD8BE" />
                <rect x="560" y="345" width="42" height="105" fill="#F6C6A3" />
                <rect x="612" y="375" width="34" height="75" fill="#FBD8BE" />
                <rect x="656" y="355" width="46" height="95" fill="#F0B98F" />
                <polygon points="656,355 679,328 702,355" fill="#DE9367" />
                <rect x="712" y="390" width="30" height="60" fill="#FBD8BE" />
              </g>

              <g fill="none" stroke="#D9530B" stroke-width="4" stroke-linecap="round" opacity="0.45">
                <path d="M200 130 q10 -8 20 0" />
                <path d="M230 145 q10 -8 20 0" />
                <path d="M480 100 q10 -8 20 0" />
              </g>
            </svg>
            <div class="absolute inset-0 bg-gradient-to-t from-white/55 via-white/0 to-brand-orange-light/10"></div>
          </div>
          <Picture
            src={fukutomiChiePortrait}
            formats={["avif", "webp"]}
            widths={heroImageWidths}
            sizes={heroImageSizes}
            alt="福富千恵"
            class="relative z-10 w-full h-[340px] sm:h-[420px] lg:h-[600px] xl:h-[640px] rounded-3xl mx-auto object-cover shadow-md"
            style="object-position: center 30%;"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- 8-2 3つのメッセージ -->
  <section class="py-14 sm:py-20">
    <div class="section-wrap">
      <div class="grid gap-8 sm:grid-cols-3">
        <MessageCard icon="heart" iconColorClass="text-accent-childcare" text={"苦しいときに、\n苦しいと言える。"} />
        <MessageCard icon="handshake" iconColorClass="text-accent-welfare" text={"助けてほしいときに、\n助けてと言える。"} />
        <MessageCard icon="smile" iconColorClass="text-brand-orange" text={"嬉しいときに、\n一緒に笑える。"} />
      </div>
    </div>
  </section>

  <!-- 8-3 基本メッセージ -->
  <section class="py-14 sm:py-20 bg-brand-ivory">
    <div class="section-wrap max-w-3xl text-center">
      <p class="text-xl sm:text-2xl text-ink leading-loose">
        生きている限りサポートを必要とするのは、お互い様だから、支え合い、助け合い、協力するのが当たり前で当然なのです。
      </p>
    </div>
  </section>

  <!-- 8-4 プロフィール概要 -->
  <section class="py-14 sm:py-16">
    <div class="section-wrap">
      <ProfileSummary />
    </div>
  </section>

  <!-- 8-5 3つの提言 -->
  <section class="py-14 sm:py-16 bg-brand-ivory">
    <div class="section-wrap">
      <SectionTitle title={visionHeading} subtitle={visionSubtitle} />
      <div class="grid gap-8 sm:grid-cols-3">
        {visionProposals.map((proposal) => (
          <VisionCard proposal={proposal} />
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href="/vision/" class="btn-secondary">私たちの提言をもっと見る</a>
      </div>
    </div>
  </section>

  <!-- 8-6 みんなの声 -->
  <section class="py-14 sm:py-16">
    <div class="section-wrap">
      <SectionTitle title={"あなたの声から、\n延岡のこれからを考えます。"} />
      <div class="max-w-2xl mx-auto text-center text-lg text-ink-soft leading-relaxed">
        <p>
          福富千恵と延岡を動かす会では、地域の皆さまの声を幅広く集め、共通する課題や異なる考え方を整理し、今後の活動や提言に生かします。
        </p>
        <p class="mt-4">
          小さな困りごと、制度について感じていること、地域を良くするためのアイデアをお寄せください。
        </p>
      </div>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="/voices/submit/" class="btn-primary">声を届ける</a>
        <a href="/voices/themes/" class="btn-secondary">現在募集中のテーマ</a>
        <a href="/voices/" class="btn-secondary">みんなの声を見る</a>
        <a href="/voices/method/" class="btn-secondary">整理方法を見る</a>
      </div>
    </div>
  </section>

  <!-- 8-7 最新の活動報告 -->
  <section class="py-14 sm:py-16 bg-brand-ivory">
    <div class="section-wrap">
      <SectionTitle title="最新の活動報告" align="left" />
      {activities.length > 0 ? (
        <div class="grid gap-8 sm:grid-cols-3">
          {activities.map((entry) => (
            <ActivityCard
              slug={entry.slug}
              title={entry.data.title}
              date={entry.data.date}
              category={entry.data.category}
              summary={entry.data.summary}
              mainImage={entry.data.mainImage}
            />
          ))}
        </div>
      ) : (
        <div class="rounded-xl bg-brand-orange-light/60 ring-1 ring-black/5 px-5 py-4 flex items-center gap-3 text-ink-soft">
          <Icon name="document" class="w-5 h-5 text-brand-orange flex-shrink-0" />
          <p>活動報告は準備中です。</p>
        </div>
      )}
      <div class="mt-8 text-center">
        {activities.length > 0 ? (
          <a href="/activities/" class="btn-secondary">活動報告一覧を見る</a>
        ) : (
          <span class="inline-flex items-center justify-center gap-2 rounded-full border-2 border-black/10 px-6 py-3 text-xl font-bold text-ink-soft/50 cursor-not-allowed" aria-disabled="true">
            活動報告一覧を見る（準備中）
          </span>
        )}
      </div>
    </div>
  </section>

  <!-- 8-8 最新のお知らせ -->
  <section class="py-14 sm:py-16">
    <div class="section-wrap">
      <SectionTitle title="最新のお知らせ" align="left" />
      {news.length > 0 ? (
        <div class="grid gap-4 sm:grid-cols-3">
          {news.map((entry) => (
            <NewsCard
              slug={entry.slug}
              title={entry.data.title}
              date={entry.data.date}
              category={entry.data.category}
              summary={entry.data.summary}
            />
          ))}
        </div>
      ) : (
        <div class="rounded-xl bg-brand-orange-light/60 ring-1 ring-black/5 px-5 py-4 flex items-center gap-3 text-ink-soft">
          <Icon name="document" class="w-5 h-5 text-brand-orange flex-shrink-0" />
          <p>お知らせは準備中です。</p>
        </div>
      )}
      <div class="mt-8 text-center">
        {news.length > 0 ? (
          <a href="/news/" class="btn-secondary">お知らせ一覧を見る</a>
        ) : (
          <span class="inline-flex items-center justify-center gap-2 rounded-full border-2 border-black/10 px-6 py-3 text-xl font-bold text-ink-soft/50 cursor-not-allowed" aria-disabled="true">
            お知らせ一覧を見る（準備中）
          </span>
        )}
      </div>
    </div>
  </section>

  {featuredVideos.length > 0 && (
    <!-- 8-8b 注目の動画 -->
    <section class="py-14 sm:py-16">
      <div class="section-wrap">
        <SectionTitle title="注目の動画" align="left" />
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {featuredVideos.map((video) => (
            <VideoCard video={video} />
          ))}
        </div>
        <div class="mt-8 text-center">
          <a href="/videos/" class="btn-secondary">動画をもっと見る</a>
        </div>
      </div>
    </section>
  )}

  <!-- 8-9 後援会案内 -->
  <section class="py-14 sm:py-16 bg-brand-ivory">
    <div class="section-wrap">
      <ContactBanner
        heading={siteConfig.organizationName}
        description={"福富千恵の活動を支え、延岡のこれからを市民の皆さまと一緒に考える政治団体です。\n地域の声を聞き、対話を重ね、支え合いと希望のある延岡を目指して活動します。"}
        primaryLabel="後援会について"
        primaryHref="/supporters/"
        secondaryLabel="後援会に入会する"
        secondaryHref="/supporters/join/"
        tertiaryLabel="お問い合わせ"
        tertiaryHref="/contact/"
      />
    </div>
  </section>
</BaseLayout>
