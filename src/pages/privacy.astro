---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/HeroSection.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import { siteConfig } from "../config/siteConfig";
import { seoConfig } from "../config/seoConfig";
import { webPageSchema } from "../utils/structuredData";
import { buildBreadcrumbList } from "../utils/seo";

const title = "プライバシーポリシー｜福富千恵と延岡を動かす会";
const description = "福富千恵と延岡を動かす会公式ホームページのプライバシーポリシーです。取得する情報、利用目的、アクセス解析サービスについて説明します。";
const breadcrumbItems = [{ name: "プライバシーポリシー", path: "/privacy" }];

const analyticsServices = [
  { name: "Google Search Console", enabled: Boolean(seoConfig.gscVerification), purpose: "検索結果での表示状況の確認" },
  { name: "Google Analytics 4", enabled: Boolean(seoConfig.ga4Id), purpose: "サイトの利用状況の把握（IPアドレスの匿名化を行います）" },
  { name: "Cloudflare Web Analytics", enabled: Boolean(seoConfig.cfAnalyticsToken), purpose: "サイトの利用状況の把握（Cookieを使用しない解析サービスです）" },
];

const schemas = [
  webPageSchema({ path: "/privacy", name: title, description }),
  buildBreadcrumbList(breadcrumbItems),
];
---

<BaseLayout title={title} description={description} path="/privacy" schemas={schemas}>
  <Breadcrumb items={breadcrumbItems} />
  <HeroSection title="プライバシーポリシー" />

  <section class="py-14 sm:py-20">
    <div class="section-wrap max-w-3xl space-y-10 text-ink-soft leading-relaxed">
      <div>
        <h2 class="text-lg font-bold text-ink mb-3">基本方針</h2>
        <p>
          {siteConfig.organizationName}（以下「当団体」）は、本ホームページ（以下「本サイト」）をご利用いただく皆さまの個人情報を適切に取り扱います。
        </p>
      </div>

      <div>
        <h2 class="text-lg font-bold text-ink mb-3">取得する情報</h2>
        <p>
          お問い合わせや「みんなの声」への投稿の際に、メールアドレスやご意見の内容など、皆さまにご提供いただく情報を取得します。氏名、詳しい住所、電話番号、勤務先、学校名、政党支持、候補者への支持・不支持、投票先などを必須で取得することはありません。
        </p>
      </div>

      <div>
        <h2 class="text-lg font-bold text-ink mb-3">利用目的</h2>
        <ul class="space-y-1">
          <li>・お問い合わせへの対応のため</li>
          <li>・寄せられたご意見の傾向を整理し、今後の活動や提言の参考とするため</li>
          <li>・本サイトの改善のため</li>
        </ul>
        <p class="mt-3">
          寄せられた意見を、個別の選挙勧誘、広告配信、政治的ターゲティングに利用することはありません。投稿内容とアクセス履歴を個人単位で結合することや、個別の支持傾向を推測することも行いません。
        </p>
      </div>

      <div>
        <h2 class="text-lg font-bold text-ink mb-3">アクセス解析サービスと外部送信について</h2>
        <p class="mb-3">本サイトでは、以下のアクセス解析サービスを利用する場合があります（測定IDが設定されていないサービスは読み込まれません）。</p>
        <div class="card overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left border-b border-black/10">
                <th class="py-2 pr-4 font-bold text-ink">サービス名</th>
                <th class="py-2 pr-4 font-bold text-ink">状態</th>
                <th class="py-2 font-bold text-ink">取得情報・利用目的</th>
              </tr>
            </thead>
            <tbody>
              {analyticsServices.map((s) => (
                <tr class="border-b border-black/5 last:border-0">
                  <td class="py-2 pr-4">{s.name}</td>
                  <td class="py-2 pr-4">{s.enabled ? "利用中" : "未設定（読み込まれません）"}</td>
                  <td class="py-2">{s.purpose}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        {seoConfig.ga4Id && (
          <div class="mt-4 space-y-4">
            <h3 class="font-bold text-ink">アクセス解析ツールについて</h3>
            <p>
              当サイトでは、サイトの利用状況を把握し、内容や利便性の改善に役立てるため、Google LLCが提供するGoogleアナリティクス4を利用しています。
            </p>
            <p>
              Googleアナリティクスでは、Cookie等を利用して、閲覧したページ、利用端末、ブラウザ、おおよその地域、サイト内での操作、アクセス日時などの情報が収集される場合があります。
            </p>
            <p>
              当サイトでは、Googleアナリティクスへ、氏名、メールアドレス、電話番号、お問い合わせ内容、フォームの回答内容、市役所案内診断の回答内容・診断結果などを送信しません。また、Googleアナリティクスを広告のパーソナライズやリマーケティングには利用しません。Googleによるデータの取扱いについては、Googleのプライバシーポリシーをご確認ください。
            </p>
            <div class="rounded-xl bg-brand-orange-light/40 p-4">
              <p class="text-sm text-ink-soft mb-3">
                アクセス解析（Googleアナリティクス4）の利用を無効にすることができます。無効にしても、本サイトの閲覧やお問い合わせ・フォームのご利用に影響はありません。
              </p>
              <button type="button" data-analytics-consent-toggle class="btn-secondary text-sm py-2 px-4">
                アクセス解析を無効にする
              </button>
              <p class="mt-2 text-xs text-ink-soft" data-analytics-consent-status></p>
            </div>
          </div>
        )}
      </div>

      <div>
        <h2 class="text-lg font-bold text-ink mb-3">「みんなの声」の取り扱い</h2>
        <p>
          寄せられた意見の原文や個人情報は、公開用のウェブサイト・リポジトリへ保存しません。事務局が内容を確認し、個人情報を削除・匿名化したうえで、分析結果として要約を公開します。詳しくは<a href="/voices/method/" class="underline text-ink font-bold">声の集め方・整理方法</a>をご覧ください。
        </p>
      </div>

      <div>
        <h2 class="text-lg font-bold text-ink mb-3">第三者提供</h2>
        <p>法令に基づく場合を除き、取得した個人情報を本人の同意なく第三者へ提供することはありません。</p>
      </div>

      <div>
        <h2 class="text-lg font-bold text-ink mb-3">お問い合わせ</h2>
        <p>
          個人情報の取り扱いに関するお問い合わせは、
          <a href={`mailto:${siteConfig.email}`} class="underline text-ink font-bold">{siteConfig.email}</a>
          までご連絡ください。
        </p>
      </div>

      <p class="text-sm text-ink-soft/70">制定日：2026年7月17日<br class="sm:hidden" /> 最終改定日：2026年7月17日</p>
    </div>
  </section>
</BaseLayout>

<script>
  import { getAnalyticsConsent, setAnalyticsConsent } from "../utils/analytics";

  const button = document.querySelector<HTMLButtonElement>("[data-analytics-consent-toggle]");
  const status = document.querySelector<HTMLElement>("[data-analytics-consent-status]");

  function render() {
    if (!button || !status) return;
    const isDenied = getAnalyticsConsent() === "denied";
    button.textContent = isDenied ? "アクセス解析を有効にする" : "アクセス解析を無効にする";
    status.textContent = isDenied ? "現在、アクセス解析は無効になっています。" : "現在、アクセス解析は有効になっています。";
  }

  button?.addEventListener("click", () => {
    setAnalyticsConsent(getAnalyticsConsent() === "denied" ? "granted" : "denied");
    render();
  });

  render();
</script>
