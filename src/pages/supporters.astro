---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/HeroSection.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import ContactBanner from "../components/ContactBanner.astro";
import RelatedContent from "../components/RelatedContent.astro";
import { siteConfig } from "../config/siteConfig";
import { webPageSchema, organizationSchema } from "../utils/structuredData";
import { buildBreadcrumbList } from "../utils/seo";

const title = "福富千恵と延岡を動かす会について";
const description = "政治団体「福富千恵と延岡を動かす会」のご紹介です。福富千恵の活動を支え、延岡のこれからを市民の皆さまと一緒に考えます。";
const breadcrumbItems = [{ name: "後援会について", path: "/supporters" }];

const schemas = [
  webPageSchema({ path: "/supporters", name: title, description }),
  organizationSchema(),
  buildBreadcrumbList(breadcrumbItems),
];
---

<BaseLayout title={title} description={description} path="/supporters" schemas={schemas}>
  <Breadcrumb items={breadcrumbItems} />
  <HeroSection title={siteConfig.organizationName} description="福富千恵の活動を支え、延岡のこれからを市民の皆さまと一緒に考える政治団体です。" />

  <section class="py-14 sm:py-20">
    <div class="section-wrap max-w-3xl space-y-10">
      <div>
        <h2 class="text-xl font-bold text-ink mb-3">団体について</h2>
        <p class="text-ink-soft leading-relaxed">
          {siteConfig.organizationName}は、地域の声を聞き、対話を重ね、支え合いと希望のある延岡を目指して活動する政治団体です。
        </p>
        <p class="mt-3 text-ink-soft leading-relaxed">
          福富千恵の経験を土台にした提言を発信するとともに、「みんなの声」を通じて市民の皆さまの意見を幅広く集め、活動へ反映させることを大切にしています。
        </p>
      </div>

      <div>
        <h2 class="text-xl font-bold text-ink mb-3">団体概要</h2>
        <dl class="card divide-y divide-black/5">
          <div class="py-3 grid grid-cols-3 gap-2">
            <dt class="text-ink-soft text-sm font-bold">団体名</dt>
            <dd class="col-span-2 text-ink">{siteConfig.organizationName}</dd>
          </div>
          <div class="py-3 grid grid-cols-3 gap-2">
            <dt class="text-ink-soft text-sm font-bold">所在地</dt>
            <dd class="col-span-2 text-ink">{siteConfig.postalCode}<br />{siteConfig.address}</dd>
          </div>
          <div class="py-3 grid grid-cols-3 gap-2">
            <dt class="text-ink-soft text-sm font-bold">メール</dt>
            <dd class="col-span-2 text-ink">
              <a href={`mailto:${siteConfig.email}`} class="text-ink font-bold underline">{siteConfig.email}</a>
            </dd>
          </div>
          <div class="py-3 grid grid-cols-3 gap-2">
            <dt class="text-ink-soft text-sm font-bold">電話番号</dt>
            <dd class="col-span-2 text-ink-soft">未設定</dd>
          </div>
        </dl>
      </div>

      <div>
        <h2 class="text-xl font-bold text-ink mb-3">活動への参加について</h2>
        <p class="text-ink-soft leading-relaxed">
          活動への参加やお手伝いにご関心をお持ちの方は、お問い合わせページよりご連絡ください。
        </p>
      </div>
    </div>
  </section>

  <section class="py-14 sm:py-20 bg-brand-ivory">
    <div class="section-wrap">
      <ContactBanner
        heading={"あなたと、延岡を動かす！"}
        description={"活動への参加や、ご意見のお寄せをお待ちしています。"}
        primaryLabel="活動に参加する"
        primaryHref="/contact"
        secondaryLabel="お問い合わせ"
        secondaryHref="/contact"
      />
    </div>
  </section>

  <div class="section-wrap">
    <RelatedContent
      items={[
        { title: "福富千恵について", href: "/profile", description: "福富千恵のプロフィールと歩みをご紹介します。" },
        { title: "私たちの提言", href: "/vision", description: "私たちの提言をご覧いただけます。" },
        { title: "お問い合わせ", href: "/contact", description: "ご意見・お問い合わせはこちらから。" },
      ]}
    />
  </div>
</BaseLayout>
