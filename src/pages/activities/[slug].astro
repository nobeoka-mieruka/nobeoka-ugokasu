---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import LastUpdated from "../../components/LastUpdated.astro";
import ShareButtons from "../../components/ShareButtons.astro";
import RelatedContent from "../../components/RelatedContent.astro";
import { getVisionProposal } from "../../data/vision";
import { articleSchema } from "../../utils/structuredData";
import { buildBreadcrumbList } from "../../utils/seo";

export async function getStaticPaths() {
  const entries = await getCollection("activities", ({ data }) => data.published);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const title = `${entry.data.title}｜福富千恵の活動報告`;
const description = entry.data.summary;
const path = `/activities/${entry.slug}`;
const breadcrumbItems = [
  { name: "活動報告", path: "/activities" },
  { name: entry.data.title, path },
];

const relatedProposals = entry.data.relatedIssues
  .map((slug) => getVisionProposal(slug))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));

const dateLabel = entry.data.date.toLocaleDateString("ja-JP", { year: "numeric", month: "long", day: "numeric" });

const schemas = [
  articleSchema({
    path,
    title: entry.data.title,
    description,
    datePublished: entry.data.date,
    dateModified: entry.data.updatedDate,
    image: entry.data.mainImage?.src,
  }),
  buildBreadcrumbList(breadcrumbItems),
];
---

<BaseLayout title={title} description={description} path={path} ogType="article" ogImage={entry.data.mainImage?.src} schemas={schemas}>
  <Breadcrumb items={breadcrumbItems} />

  <article class="section-wrap py-10 sm:py-16 max-w-3xl">
    <div class="flex items-center gap-3 text-xs text-ink-soft mb-3">
      <span class="rounded-full bg-brand-orange-light px-2 py-0.5 font-bold text-ink">{entry.data.category}</span>
      <time datetime={entry.data.date.toISOString()}>{dateLabel}</time>
      {entry.data.location && <span>{entry.data.location}</span>}
    </div>
    <h1 class="text-2xl sm:text-3xl font-bold text-ink leading-snug">{entry.data.title}</h1>

    {entry.data.mainImage && (
      <img
        src={entry.data.mainImage.src}
        alt={entry.data.mainImage.alt}
        class="mt-6 w-full rounded-2xl object-cover"
        loading="eager"
      />
    )}

    <div class="mt-8 prose-content text-ink-soft leading-loose space-y-4">
      <Content />
    </div>

    <div class="mt-10 flex flex-wrap items-center justify-between gap-4">
      <LastUpdated date={entry.data.updatedDate ?? entry.data.date} />
      <ShareButtons path={path} title={entry.data.title} />
    </div>
  </article>

  <div class="section-wrap">
    <RelatedContent
      items={[
        ...relatedProposals.map((p) => ({
          title: p.shortTitle,
          href: `/issues/${p.slug}`,
          description: "この活動に関連する提言です。",
        })),
        { title: "活動報告一覧へ戻る", href: "/activities", description: "他の活動報告もご覧いただけます。" },
      ]}
    />
  </div>
</BaseLayout>
