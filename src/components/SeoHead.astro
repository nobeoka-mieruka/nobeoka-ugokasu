---
import { siteConfig } from "../config/siteConfig";
import { seoConfig } from "../config/seoConfig";
import { absoluteUrl, shouldNoindex } from "../utils/seo";

interface Props {
  title: string;
  description: string;
  path: string;
  ogImage?: string;
  ogType?: "website" | "article" | "profile";
  noindex?: boolean;
  /** og:title / twitter:title を<title>と別の文言にしたい場合に指定 */
  ogTitle?: string;
  /** og:description / twitter:description をmeta descriptionと別の文言にしたい場合に指定 */
  ogDescription?: string;
  /** og:image:alt / twitter:image:alt。省略時は既定のサイト説明文を使用 */
  ogImageAlt?: string;
}

const {
  title,
  description,
  path,
  ogImage = siteConfig.defaultOgpImage,
  ogType = "website",
  noindex = false,
  ogTitle,
  ogDescription,
  ogImageAlt = `${siteConfig.organizationName}の公式ホームページ`,
} = Astro.props;

const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDescription = ogDescription ?? description;

const canonicalUrl = absoluteUrl(path);
const ogImageUrl = ogImage.startsWith("http") ? ogImage : absoluteUrl(ogImage);
const isNoindex = shouldNoindex(noindex);
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<meta
  name="robots"
  content={isNoindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"}
/>

<meta property="og:title" content={resolvedOgTitle} />
<meta property="og:description" content={resolvedOgDescription} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={siteConfig.siteName} />
<meta property="og:locale" content={siteConfig.locale} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content={String(seoConfig.ogpImageWidth)} />
<meta property="og:image:height" content={String(seoConfig.ogpImageHeight)} />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:alt" content={ogImageAlt} />

<meta name="twitter:card" content={seoConfig.twitterCard} />
<meta name="twitter:title" content={resolvedOgTitle} />
<meta name="twitter:description" content={resolvedOgDescription} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:image:alt" content={ogImageAlt} />

{seoConfig.gscVerification && (
  <meta name="google-site-verification" content={seoConfig.gscVerification} />
)}
{seoConfig.bingVerification && (
  <meta name="msvalidate.01" content={seoConfig.bingVerification} />
)}

{seoConfig.ga4Id && (
  <script>
    // 実際の読み込み判定（本番ホストか・計測に同意しているか）と主要リンクの自動計測は
    // src/scripts/analyticsBootstrap.ts が行う。ここでは1ページにつき1回だけ読み込む。
    import "../scripts/analyticsBootstrap";
  </script>
)}

{seoConfig.cfAnalyticsToken && (
  <script
    is:inline
    defer
    src="https://static.cloudflareinsights.com/beacon.min.js"
    data-cf-beacon={`{"token": "${seoConfig.cfAnalyticsToken}"}`}
  ></script>
)}
