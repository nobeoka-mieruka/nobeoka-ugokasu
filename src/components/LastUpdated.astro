---
interface Props {
  date?: Date | string;
}

const { date } = Astro.props;
const parsedDate = date instanceof Date ? date : date ? new Date(date) : undefined;
const dateObj = parsedDate && !Number.isNaN(parsedDate.getTime()) ? parsedDate : undefined;
const label = dateObj
  ? dateObj.toLocaleDateString("ja-JP", { year: "numeric", month: "long", day: "numeric" })
  : undefined;
---

{label && dateObj && (
  <p class="text-sm text-ink-soft">
    最終更新日：<time datetime={dateObj.toISOString()}>{label}</time>
  </p>
)}
