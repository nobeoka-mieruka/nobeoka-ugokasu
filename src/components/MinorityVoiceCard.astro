---
import Icon from "./Icon.astro";

interface Props {
  items: string[];
}

const { items } = Astro.props;
---

{items.length > 0 && (
  <div class="card border-l-4 border-brand-orange">
    <h3 class="font-bold text-ink flex items-center gap-2">
      <Icon name="heart" class="w-5 h-5 text-brand-orange" />
      少数でも重要な意見
    </h3>
    <ul class="mt-3 space-y-2">
      {items.map((item) => (
        <li class="text-ink-soft text-sm leading-relaxed">{item}</li>
      ))}
    </ul>
  </div>
)}
