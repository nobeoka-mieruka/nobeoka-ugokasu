---
// サイト全体の最終更新日時（GitHub mainブランチへ反映された最新コミットの日時）を表示する。
// scripts/generate-build-info.mjs がビルド前に生成する src/data/build-info.json を読み込む。
// 日時が取得できない場合は、何も表示しない（TODO・undefined・Invalid Dateは表示しない）。
import buildInfo from "../data/build-info.json";

const parsed = buildInfo?.lastUpdated ? new Date(buildInfo.lastUpdated) : null;
const isValid = parsed !== null && !Number.isNaN(parsed.getTime());

const label = isValid
  ? parsed.toLocaleString("ja-JP", {
      timeZone: "Asia/Tokyo",
      year: "numeric",
      month: "long",
      day: "numeric",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false,
    })
  : null;
---

{label && isValid && (
  <p class="text-xs text-white/60">
    サイト最終更新日時：<time datetime={parsed.toISOString()}>{label}</time>
  </p>
)}
