---
import { siteConfig } from "../config/siteConfig";
import { headerNav } from "../data/navigation";
import MobileMenu from "./MobileMenu.astro";
import MobileMenuPanel from "./MobileMenuPanel.astro";
import SocialLinks from "./SocialLinks.astro";

const currentPath = Astro.url.pathname;

function isCurrent(href: string, path: string) {
  if (href === "/") return path === "/";
  return path === href || path.startsWith(`${href}/`);
}
---

<header class="sticky top-0 z-40 bg-brand-ivory/95 backdrop-blur border-b border-black/5">
  <div class="header-wrap flex items-center justify-between gap-4 py-2.5">
    <a href="/" class="flex-shrink-0 min-w-0">
      <img
        src="/images/logo/kouenkainamaeirilogo.png"
        alt={siteConfig.organizationName}
        width="2172"
        height="724"
        class="w-[220px] sm:w-[260px] 2xl:w-[360px] h-auto"
      />
    </a>

    <nav aria-label="メインメニュー" class="hidden xl:block min-w-0">
      <ul class="flex items-center gap-2 xl:gap-3">
        {headerNav.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                "inline-block whitespace-nowrap rounded-lg px-1.5 py-2 text-[14px] font-bold transition-colors border-b-2",
                isCurrent(item.href, currentPath)
                  ? "text-ink bg-brand-orange-light border-brand-orange-dark"
                  : "text-ink border-transparent hover:bg-brand-orange-light hover:border-brand-orange-dark",
              ]}
              aria-current={isCurrent(item.href, currentPath) ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    {/*
      1280〜1535px（xl帯）は、ナビゲーション項目自体がこの幅で既に目一杯のため、
      アイコンを追加すると重なってしまう。2xl（1536px）から表示することで、
      どの画面幅でも文字とアイコンが重ならないようにしている。
      1536px未満でもフッターから常にFacebook/Instagramへアクセスできる。
    */}
    <div class="hidden 2xl:flex flex-shrink-0 items-center">
      <SocialLinks />
    </div>

    <MobileMenu />
  </div>
</header>

<MobileMenuPanel items={headerNav} currentPath={currentPath} />
