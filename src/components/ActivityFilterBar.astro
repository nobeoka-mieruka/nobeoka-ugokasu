---
const filters = [
  { key: "all", label: "すべて" },
  { key: "website", label: "公式サイト" },
  { key: "facebook", label: "Facebook" },
  { key: "instagram", label: "Instagram" },
] as const;
---

<div role="tablist" aria-label="活動報告の絞り込み" class="mb-8 flex flex-wrap gap-2" data-activity-filter-bar>
  {filters.map((f, i) => (
    <button
      type="button"
      id={`activity-tab-${f.key}`}
      role="tab"
      data-activity-filter={f.key}
      aria-selected={i === 0 ? "true" : "false"}
      aria-controls="activity-grid"
      tabindex={i === 0 ? 0 : -1}
      class:list={[
        "rounded-full border-2 px-5 py-2.5 text-sm font-bold text-ink transition-colors",
        i === 0
          ? "border-brand-orange-dark bg-brand-orange-light"
          : "border-black/10 bg-white hover:bg-brand-orange-light",
      ]}
    >
      {f.label}
    </button>
  ))}
</div>

<script>
  // SNS自動取得カードはページ読み込み後に非同期で追加されるため、カード一覧は
  // 都度 document から取得し直す（ページ読み込み時点のスナップショットにしない）。
  const filterBar = document.querySelector<HTMLElement>("[data-activity-filter-bar]");
  const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-activity-filter]"));
  const grid = document.getElementById("activity-grid");
  let currentFilter = "all";

  function applyFilter(filter: string) {
    currentFilter = filter;
    let visibleCount = 0;

    document.querySelectorAll<HTMLElement>("[data-activity-card]").forEach((card) => {
      const platforms = (card.dataset.platforms ?? "website").split(" ");
      const matches = filter === "all" || platforms.includes(filter);
      card.classList.toggle("hidden", !matches);
      if (matches) visibleCount += 1;
    });

    document.querySelectorAll<HTMLElement>("[data-empty-for]").forEach((el) => {
      const isCurrent = el.dataset.emptyFor === filter;
      el.classList.toggle("hidden", !(isCurrent && visibleCount === 0));
    });
  }

  function activate(button: HTMLButtonElement, focus: boolean) {
    buttons.forEach((b) => {
      const isActive = b === button;
      b.setAttribute("aria-selected", String(isActive));
      b.tabIndex = isActive ? 0 : -1;
      b.classList.toggle("border-brand-orange-dark", isActive);
      b.classList.toggle("bg-brand-orange-light", isActive);
      b.classList.toggle("border-black/10", !isActive);
      b.classList.toggle("bg-white", !isActive);
    });

    if (focus) button.focus();
    if (grid) grid.setAttribute("aria-labelledby", button.id);
    applyFilter(button.dataset.activityFilter ?? "all");
  }

  filterBar?.addEventListener("click", (event) => {
    const button = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-activity-filter]");
    if (!button) return;
    activate(button, false);
  });

  // WAI-ARIA Tabsパターンに沿った矢印キー操作（フォーカス移動と同時に切り替える）
  filterBar?.addEventListener("keydown", (event) => {
    const current = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-activity-filter]");
    if (!current) return;
    const index = buttons.indexOf(current);
    if (index === -1) return;

    let nextIndex: number | null = null;
    if (event.key === "ArrowRight") nextIndex = (index + 1) % buttons.length;
    else if (event.key === "ArrowLeft") nextIndex = (index - 1 + buttons.length) % buttons.length;
    else if (event.key === "Home") nextIndex = 0;
    else if (event.key === "End") nextIndex = buttons.length - 1;

    if (nextIndex === null) return;
    event.preventDefault();
    activate(buttons[nextIndex], true);
  });

  // SNS自動取得カードの挿入後、現在の絞り込み状態を再適用してもらうためのイベント
  document.addEventListener("social-posts:updated", () => {
    applyFilter(currentFilter);
  });
</script>
