---
interface Props {
  title: string;
  subtitle?: string;
  align?: "left" | "center";
}

const { title, subtitle, align = "center" } = Astro.props;
---

<div class:list={["mb-10 sm:mb-12", align === "center" ? "text-center" : "text-left"]}>
  <h2 class="text-3xl sm:text-4xl font-bold text-ink whitespace-pre-line">{title}</h2>
  {subtitle && (
    <p class="mt-4 text-lg sm:text-xl text-ink-soft whitespace-pre-line leading-relaxed">{subtitle}</p>
  )}
</div>
