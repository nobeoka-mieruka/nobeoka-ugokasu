---
import Icon from "../Icon.astro";
---

<section data-cg-screen="question" hidden>
  <button type="button" class="inline-flex items-center gap-1 text-sm font-bold text-ink-soft hover:text-ink mb-6" data-cg-back>
    <Icon name="chevron-left" class="w-4 h-4" />
    カテゴリ選びに戻る
  </button>

  <div class="card text-center py-10 px-6 sm:px-10">
    <p class="text-xs font-bold text-brand-orange-dark mb-2" data-cg-category-label></p>
    <p class="text-xl sm:text-2xl font-bold text-ink leading-relaxed" data-cg-question-text></p>

    <div class="mt-8 flex flex-col sm:flex-row items-stretch justify-center gap-4">
      <button
        type="button"
        class="rounded-full px-8 py-4 text-xl font-bold text-white bg-accent-welfare shadow-sm hover:brightness-110 transition-all"
        data-cg-answer="yes"
      >
        はい
      </button>
      <button
        type="button"
        class="rounded-full px-8 py-4 text-xl font-bold text-white bg-ink-soft shadow-sm hover:brightness-110 transition-all"
        data-cg-answer="no"
      >
        いいえ
      </button>
    </div>
  </div>
</section>
