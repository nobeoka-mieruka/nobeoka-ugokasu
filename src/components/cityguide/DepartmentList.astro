---
import Icon from "../Icon.astro";
import type { CityDepartment } from "../../data/cityGuideData";

interface Props {
  departments: CityDepartment[];
}

const { departments } = Astro.props;
---

<section data-cg-screen="list" hidden>
  <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
    <h2 class="text-xl font-bold text-ink">担当課の一覧から探す</h2>
    <button type="button" class="inline-flex items-center gap-1 text-sm font-bold text-ink-soft hover:text-ink" data-cg-restart>
      <Icon name="chevron-left" class="w-4 h-4" />
      診断に戻る
    </button>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {departments.map((dept) => (
      <div class="card min-w-0">
        <h3 class="font-bold text-ink [overflow-wrap:break-word]">{dept.name}</h3>
        <p class="mt-2 text-sm text-ink-soft leading-relaxed [overflow-wrap:break-word]">{dept.summary}</p>
        {dept.officialUrl && (
          <a href={dept.officialUrl} target="_blank" rel="noopener noreferrer" class="mt-3 inline-flex items-center gap-1 text-sm font-bold text-ink hover:underline">
            公式ページ
            <Icon name="external-link" class="w-4 h-4" />
          </a>
        )}
      </div>
    ))}
  </div>
</section>
