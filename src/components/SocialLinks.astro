---
import { socialLinks } from "../data/socialLinks";
import Icon from "./Icon.astro";

const links = [
  { key: "line", label: "LINE公式アカウントを開く", icon: "line" as const },
  {
    key: "facebook",
    label: "福富千恵と延岡を動かす会のFacebookを開く",
    icon: "facebook" as const,
  },
  { key: "instagram", label: "福富千恵さんのInstagramを開く", icon: "instagram" as const },
  { key: "youtube", label: "YouTubeチャンネルを開く", icon: "youtube" as const },
] satisfies { key: keyof typeof socialLinks; label: string; icon: "line" | "instagram" | "facebook" | "youtube" }[];

const active = links.filter((l) => socialLinks[l.key]);
---

{active.length > 0 && (
  <ul class="flex items-center gap-3">
    {active.map((link) => (
      <li>
        <a
          href={socialLinks[link.key]}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={link.label}
          class="inline-flex items-center justify-center rounded-full bg-brand-orange-light p-2 text-brand-orange-dark hover:bg-brand-orange hover:text-white transition-colors"
        >
          <Icon name={link.icon} class="w-5 h-5" />
        </a>
      </li>
    ))}
  </ul>
)}
