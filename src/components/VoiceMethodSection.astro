---
import Icon from "./Icon.astro";
import { voicesConfig } from "../config/voicesConfig";

interface Props {
  heading?: string;
}

const { heading = "声の集め方" } = Astro.props;
---

<div>
  <h2 class="text-xl font-bold text-ink mb-4">{heading}</h2>
  <p class="text-ink-soft leading-relaxed mb-4">
    デジタルを利用しない方のご意見も大切にしたいと考えており、以下の方法で声を集めています。
  </p>
  <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
    {voicesConfig.collectionMethods.map((method) => (
      <li class="card flex items-center gap-3 py-4">
        <Icon name="users" class="w-5 h-5 flex-shrink-0 text-brand-orange" />
        <span class="text-ink font-bold text-sm">{method}</span>
      </li>
    ))}
  </ul>
</div>
