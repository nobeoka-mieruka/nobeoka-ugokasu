---
import Icon from "./Icon.astro";

interface Props {
  icon: "heart" | "handshake" | "smile";
  iconColorClass: string;
  text: string;
}

const { icon, iconColorClass, text } = Astro.props;
---

<div class="card flex flex-col items-center text-center gap-5 py-10">
  <span class:list={["inline-flex items-center justify-center w-20 h-20 rounded-full bg-brand-orange-light", iconColorClass]}>
    <Icon name={icon} class="w-10 h-10" />
  </span>
  <p class="text-xl font-bold text-ink whitespace-pre-line leading-relaxed">{text}</p>
</div>
